# Copy to .env for local development. Never commit .env.
# Platform column: Railway = both backend services, Vercel = apps/web, CLI = local Prisma commands only.

# Pooled Neon connection string (PgBouncer endpoint). Set on: Railway (http-backend, ws-backend), local .env.
DATABASE_URL="postgresql://USER:PASSWORD@POOLED-HOST/DBNAME?sslmode=require"

# Direct (non-pooled) Neon connection string. Used only by the Prisma CLI for migrations. Set on: CLI/local only.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@DIRECT-HOST/DBNAME?sslmode=require"

# Secret used to sign and verify JWTs. Must be identical on both backends. Generate with: openssl rand -hex 32. Set on: Railway (both services).
JWT_SECRET="CHANGE-ME-64-HEX-CHARS"

# Comma-separated list of allowed browser origins. Set on: Railway (both services). http-backend defaults to http://localhost:3000 when unset; ws-backend allows all origins when unset.
CORS_ORIGINS="https://your-app.vercel.app"

# Standard Node environment. Railway and Vercel set this automatically; only set locally if needed.
NODE_ENV="development"

# Public base URL of the HTTP backend, baked into the frontend at build time. Set on: Vercel.
NEXT_PUBLIC_HTTP_URL="https://your-http-backend.up.railway.app"

# Public WebSocket URL of the ws backend (wss:// in production), baked into the frontend at build time. Set on: Vercel.
NEXT_PUBLIC_WS_URL="wss://your-ws-backend.up.railway.app"
