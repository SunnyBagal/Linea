generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  password   String
  username   String
  image      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  rooms      Room[]
  operations Operation[]
  chats      Chat[]
}

model Room {
  id         Int          @id @default(autoincrement())
  slug       String       @unique
  createdAt  DateTime     @default(now())
  adminId    String
  admin      User         @relation(fields: [adminId], references: [id])

  currentSeq Int          @default(0)   
  operations Operation[]
  snapshots  Snapshot[]
  chats      Chat[]

  @@index([adminId])
}

enum OpType {
  CREATE
  UPDATE
  DELETE
}

model Operation {
  id        BigInt   @id @default(autoincrement())
  roomId    Int
  seq       Int                      
  type      OpType
  shapeId   String                   
  payload   Json                     
  userId    String
  createdAt DateTime @default(now())

  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([roomId, seq])            
  @@index([roomId, shapeId])         
}

model Snapshot {
  id        BigInt   @id @default(autoincrement())
  roomId    Int
  seq       Int                      
  state     Json                     
  createdAt DateTime @default(now())

  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, seq])
}

model Chat {
  id        Int      @id @default(autoincrement())
  userId    String
  roomId    Int
  message   String
  createdAt DateTime @default(now())

  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([roomId])
}