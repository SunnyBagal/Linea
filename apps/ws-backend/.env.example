# WebSocket backend (ws, Railway service)

# Postgres connection string (Railway/Neon). Read at runtime by @repo/db.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Secret used to sign/verify JWTs. Must match the http-backend value.
JWT_SECRET="change-me"

# Injected automatically by Railway. Local dev falls back to 8080 if unset.
# PORT=8080

# Comma-separated allowlist of browser origins permitted to open a WS
# connection. When unset (local dev), all origins are allowed.
CORS_ORIGINS="http://localhost:3000"
