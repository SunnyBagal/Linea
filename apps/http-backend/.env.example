# HTTP backend (Express, Railway service)

# Postgres connection string (Railway/Neon). Read at runtime by @repo/db.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Secret used to sign/verify JWTs. Must match the ws-backend value.
JWT_SECRET="change-me"

# Injected automatically by Railway. Local dev falls back to 3005 if unset.
# PORT=3005

# Comma-separated list of allowed CORS origins. Add the Vercel prod domain here.
# Defaults to the local dev frontend when unset.
CORS_ORIGINS="http://localhost:3000"
